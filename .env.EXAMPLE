# nome do usuario para logar no site em /admin/login
LOGIN_USER='SEU USUARIO AQUI'
Use o arquivo src/utils/generate-hashed-password.ts (npx tsx) para gerar seu hash de senha
LOGIN_PASS='SEU HASH DE SENHA AQUI'

# permite ou nao login (0 = nao, 1 = sim)
ALLOW_LOGIN=1